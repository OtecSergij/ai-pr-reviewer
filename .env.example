# --- App ---
# Public origin of the app. Used as metadataBase for the absolute OpenGraph /
# Twitter card and icon URLs. Empty → http://localhost:3000 (local dev). In
# production: https://reviewer.zablotsky.dev
APP_URL=

# --- GitHub ---
# Server-side token for reviewing PUBLIC PRs (also raises GitHub's rate limit).
# Scope it to public repositories only (classic PAT: public_repo) so it cannot
# read private repos — the in-code private-PR gate is then a safety net, not the
# sole defense.
# Private PRs use the user's own PAT, passed per request — not this variable.
GITHUB_PAT=

# --- LLM providers (free fallback chain, ordered by ascending context) ---
# Cerebras / zai-glm-4.7 — default provider (free tier, strongest free tool-caller).
CEREBRAS_API_KEY=
# Groq / openai/gpt-oss-120b — first fallback (free tier).
GROQ_API_KEY=
# Google / gemini-2.5-flash — last fallback, big-context safety net (free tier).
GOOGLE_GENERATIVE_AI_API_KEY=
# Anthropic premium runs on the user's BYO key, passed per request — NOT from env.

# --- Dev ---
# Empty / any value other than "1" — normal behavior (real reviews, needs the
# provider keys above). "1" — /api/review streams a fixture mock WITHOUT any keys
# (keyless dev/demo, the LLM is never called); paste
# https://github.com/vercel/ms/pull/35 into the form.
MOCK_REVIEW=
# Only applies when MOCK_REVIEW=1. Injects an error/scenario to exercise the UI
# error taxonomy. Allowed values: api-retryable, retry-exhausted, api-400,
# load-key, unknown, tool-outcomes. Empty — no injection.
MOCK_ERROR=

# --- Datastores ---
# Postgres — share-URL store for public reviews.
# Local dev: docker run -d --name pr-reviewer-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=pr_reviewer -p 5432:5432 postgres:18-alpine
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pr_reviewer
# Redis — per-IP rate limiter.
# Local dev: docker run -d --name pr-reviewer-redis -p 6379:6379 redis:8-alpine
REDIS_URL=redis://localhost:6379
# "1" — client IP is taken from the rightmost X-Forwarded-For entry. Enable ONLY
# when the app is reachable exclusively through a trusted reverse-proxy (Traefik
# in Coolify). Empty — all requests share one "dev" bucket (local development).
TRUST_PROXY=
