# --- GitHub ---
# Server-side token for reviewing PUBLIC PRs (also raises GitHub's rate limit).
# Private PRs use the user's own PAT, passed per request — not this variable.
GITHUB_PAT=

# --- LLM providers ---
# Gemini 2.0 Flash — default provider (free tier).
GOOGLE_GENERATIVE_AI_API_KEY=
# Groq / Llama 3.3 70B — fallback provider (free tier).
GROQ_API_KEY=
# Anthropic — OPTIONAL. Premium reviews run on the user's BYO key;
# set this only to test the premium path locally.
ANTHROPIC_API_KEY=

# --- Datastores ---
# Postgres — share-URL store for public reviews.
DATABASE_URL=
# Redis — per-IP rate limiter.
REDIS_URL=
